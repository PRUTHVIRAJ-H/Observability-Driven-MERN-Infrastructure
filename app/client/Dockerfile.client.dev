# 1. Use Node 22 (Full version) for maximum compatibility with all libraries
FROM node:22

# 2. Define build-time environment variables
ENV NODE_ENV=development

# 3. Set the working directory
WORKDIR /app/client

# 4. Copy package files first for better caching
COPY package.json yarn.lock* ./

# 5. Install all dependencies
# We use 'yarn install' to ensure React Router and Axios are correctly linked
RUN yarn install

# 6. Copy all your JSX files, Header, Footer, and other components
COPY . .

# 7. Expose the port used by React
EXPOSE 3000

# 8. Start the development server
# --host 0.0.0.0 is mandatory for Docker to talk to the browser
CMD ["yarn", "start", "--host", "0.0.0.0"]
