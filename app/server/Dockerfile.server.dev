# 1. Use Node 22 (Full) for maximum compatibility and stability
FROM node:22

# 2. Set the working directory
WORKDIR /app/server

# 3. Copy dependency files first to leverage Docker layer caching
COPY package.json yarn.lock* ./

# 4. Install dependencies
# We use yarn install and then add nodemon for development
RUN yarn install && yarn global add nodemon

# 5. Copy the rest of the backend source code
COPY . .

# 6. Expose the API port (as defined in your server.js)
EXPOSE 4000

# 7. Start the server using nodemon for hot-reloading
# This ensures the server restarts whenever you edit server.js
CMD ["nodemon", "src/server.jsx"]